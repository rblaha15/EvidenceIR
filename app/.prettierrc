{
    "plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
    "overrides": [{ "files": "*.svelte", "options": { "parser": "svelte" } }],
    "printWidth": 140,
    "tabWidth": 4,
    "singleQuote": true,
    "arrowParens": "avoid",
    "tailwindStylesheet": "./src/routes/layout.css",
    "tailwindFunctions": ["cn", "tv"]
}
